class ReverseStringSteps {

    public static void main(String[] args) {

        String str = "jyothikaa";
        String reversed = "";

        System.out.println("Original String: " + str);
        System.out.println("String Length: " + str.length());
        System.out.println("Starting from index: " + (str.length() - 1));
        System.out.println("--------------------------------");

        for (int i = str.length() - 1; i >= 0; i--) {

            System.out.println("i = " + i);
            System.out.println("Character at index " + i + " = " + str.charAt(i));

            reversed = reversed + str.charAt(i);

            System.out.println("Reversed so far = " + reversed);
            System.out.println("--------------------------------");
        }

        System.out.println("Final Reversed String: " + reversed);
    }
}
