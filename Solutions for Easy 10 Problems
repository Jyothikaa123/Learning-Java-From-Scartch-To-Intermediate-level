class ArmstrongNumber {

    public static void main(String[] args) {

        int num = 153;
        
        int sum = 0;
        int digits = 0;

        
        int temp = num;
        while (temp > 0) {
            digits++;
            temp = temp / 10;
        }

       
        temp = num;
        while (temp > 0) {
            int digit = temp % 10;
            sum = sum + (int) Math.pow(digit, digits);
            temp = temp / 10;
        }

       
        if (sum == num) {
            System.out.println(num + " is an Armstrong number");
        } else {
            System.out.println(num+ " is NOT an Armstrong number");
        }
    }
}
