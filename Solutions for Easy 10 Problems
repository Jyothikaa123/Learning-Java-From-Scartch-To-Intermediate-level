for bubble sort 
bubble sort means compare two neighbour numbers 
if wrong order then swap them

class BubbleSort {
    public static void main(String[] args) {

        int[] arr = {5, 3, 8, 2};
        int n=arrr.length;
        for (int i = 0; i < n - 1; i++) {      // OUTER LOOP
            for (int j = 0; j < n- 1 - i; j++) {  // INNER LOOP

                if (arr[j] > arr[j + 1]) {
                    // swap
                    int temp = arr[j];
                    arr[j] = arr[j + 1];
                    arr[j + 1] = temp;
                }
            }
        }

        // print sorted array
        for (int num : arr) {
            System.out.print(num + " ");
        }
    }
}
